# ─── Versus App — Environment Variables ───────────────────────────────────────
# Copy this file to .env and fill in the values before running `npm run dev`.
# NEVER commit .env to git — it is listed in .gitignore.

# Your Supabase project URL (Settings → API → Project URL)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Your Supabase anon/public key (Settings → API → Project API keys → anon public)
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Your Anthropic API key (console.anthropic.com → API Keys)
# Used client-side for AI comment moderation and seed generation.
# Move to a Supabase Edge Function in v2 to keep this key server-side.
VITE_ANTHROPIC_API_KEY=sk-ant-...

# The public URL of your deployed app (used in share text)
VITE_APP_URL=https://versus.app
